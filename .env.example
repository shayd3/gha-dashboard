# GitHub App (see README.md → GitHub App Setup)
GITHUB_APP_CLIENT_ID=your_app_client_id
GITHUB_APP_CLIENT_SECRET=your_app_client_secret
# Optional: for future installation-token features
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=

# JWT secret for session cookies
JWT_SECRET=change-me-to-a-random-string

# Backend
PORT=3000
NODE_ENV=development

# Frontend URL — where the frontend is served from (used for OAuth callback + redirect)
# For local dev: http://localhost:5173  |  Docker Compose: http://localhost  |  Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# CORS origin — must match the frontend URL
CORS_ORIGIN=http://localhost:5173

# PostgreSQL — optional; omit to use in-memory view storage (not persisted across restarts)
# DATABASE_URL=postgresql://gha:gha@localhost:5432/gha_dashboard

# GitHub API (for Enterprise, change to your instance)
GITHUB_API_URL=https://api.github.com
